rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role != null ? request.auth.token.role : "";
    }

    function canReadInventory() {
      return isLoggedIn() && (
        role() == "Administrador" ||
        role() == "Supervisor" ||
        role() == "Operador" ||
        role() == "Consulta" ||
        role() == "Auditor"
      );
    }

    function canWriteInventory() {
      return isLoggedIn() && (
        role() == "Administrador" ||
        role() == "Supervisor" ||
        role() == "Operador"
      );
    }

    function canDeleteInventory() {
      return isLoggedIn() && (
        role() == "Administrador" ||
        role() == "Supervisor"
      );
    }

    function canReadAudit() {
      return isLoggedIn() && (
        role() == "Administrador" ||
        role() == "Supervisor" ||
        role() == "Auditor"
      );
    }

    function canCreateAudit() {
      return isLoggedIn() && (
        role() == "Administrador" ||
        role() == "Supervisor" ||
        role() == "Auditor"
      );
    }

    function isValidAudit(data) {
      return data.keys().hasAll(["tipo", "usuario", "detalle", "fecha"]) &&
        data.tipo is string &&
        data.usuario is string &&
        data.detalle is string &&
        data.fecha is string;
    }

    function isValidInventory(data) {
      return data.keys().hasAll([
          "id",
          "descripcion",
          "categoria",
          "cantidad",
          "unidad",
          "nroRemito",
          "fecha",
          "fechaCarga",
          "tipo",
          "estado",
          "estadoRemito"
        ]) &&
        data.id is string &&
        data.descripcion is string &&
        data.categoria is string &&
        data.cantidad is number &&
        data.unidad is string &&
        data.nroRemito is string &&
        data.fecha is string &&
        data.fechaCarga is string &&
        data.tipo is string &&
        data.estado is string &&
        data.estadoRemito is string &&
        (data.motivo is string || !data.keys().hasAny(["motivo"])) &&
        (data.fechaCompra is string || !data.keys().hasAny(["fechaCompra"])) &&
        (data.fechaVencimiento is string || !data.keys().hasAny(["fechaVencimiento"])) &&
        (data.fechaCierre is string || !data.keys().hasAny(["fechaCierre"])) &&
        (data.foto is string || data.foto is list || !data.keys().hasAny(["foto"]));
    }

    match /inventario_mdh/{docId} {
      allow read: if canReadInventory();
      allow create, update: if canWriteInventory() && isValidInventory(request.resource.data);
      allow delete: if canDeleteInventory() && isValidInventory(request.resource.data);
    }

    match /auditoria/{auditId} {
      allow read: if canReadAudit();
      allow create: if canCreateAudit() && isValidAudit(request.resource.data);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
